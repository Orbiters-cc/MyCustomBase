.mcb-root {
    background-color: rgba(0,0,0,0);
    padding-bottom: 8px;
    margin-left: -15px;
    margin-right: -15px;
    position: relative;
    overflow: visible;
}

.mcb-chrome-surface {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
}

.mcb-surface {
    background-color: rgba(0,0,0,0);
    padding: 36px 24px 26px 24px;
    position: relative;
    overflow: visible;
}

.mcb-row {
    flex-direction: row;
}

.mcb-label {
    -unity-text-align: middle-left;
}

.mcb-label--section {
    color: #c8c8c8;
    font-size: 12px;
    -unity-font-style: bold;
}

.mcb-label--strong {
    color: #ffffff;
    -unity-font-style: bold;
}

.mcb-label--muted {
    color: #999999;
}

.mcb-message {
    white-space: normal;
    margin-top: 8px;
    margin-bottom: 8px;
}

.mcb-button {
    height: 26px;
    background-color: #595959;
    color: #ffffff;
    border-width: 0;
    border-radius: 8px;
    padding-left: 10px;
    padding-right: 10px;
    cursor: link;
}

.mcb-button:hover {
    background-color: #6a6a6a;
}

.mcb-button--primary {
    min-height: 36px;
    height: 36px;
    border-radius: 8px;
    background-color: #00DA6D;
    -unity-font-style: bold;
}

.mcb-button--primary:hover {
    background-color: #00DA6D;
}

.mcb-button:disabled {
    opacity: 0.55;
}

.mcb-button Label {
    color: #ffffff;
}

.mcb-button--flat {
    height: 17px;
    min-height: 17px;
    background-color: #5b5b5b;
    border-radius: 8px;
    font-size: 12px;
    padding-top: 0;
    padding-bottom: 1px;
}

.mcb-button--toolbar {
    margin-right: 8px;
}

.mcb-button--icon {
    flex-direction: row;
    align-items: center;
    padding-left: 10px;
    padding-right: 10px;
}

.mcb-button--icon-only {
    width: 24px;
    height: 24px;
    min-width: 24px;
    min-height: 24px;
    padding: 0;
    justify-content: center;
    align-items: center;
}

.mcb-button-icon {
    width: 15px;
    height: 15px;
    margin-right: 6px;
}

.mcb-button--icon-only .mcb-button-icon {
    margin-right: 0;
}

.mcb-dropdown {
    height: 28px;
    margin-left: 0;
    margin-right: 0;
}

.mcb-dropdown .unity-base-field__input,
.mcb-dropdown .unity-popup-field__input {
    min-height: 28px;
    height: 28px;
    background-color: #464646;
    border-color: #c8c8c8;
    border-width: 1px;
    border-radius: 14px;
    color: #ffffff;
    padding-left: 12px;
    padding-right: 8px;
    cursor: link;
}

.mcb-dropdown:hover .unity-base-field__input,
.mcb-dropdown:hover .unity-popup-field__input {
    background-color: #505050;
}

.mcb-form-card {
    background-color: #212121;
    border-radius: 8px;
    padding: 14px;
}

.mcb-dependencies {
    background-color: rgba(0,0,0,0);
    padding: 8px 24px 24px 24px;
    flex-grow: 0;
    flex-shrink: 0;
}

.mcb-dependencies__panel {
    background-color: #191919;
    border-radius: 8px;
    border-left-width: 4px;
    border-left-color: #ff8c59;
    padding: 18px 18px 16px 18px;
}

.mcb-dependencies__eyebrow {
    color: #ffb18c;
    font-size: 11px;
    -unity-font-style: bold;
}

.mcb-dependencies__title {
    margin-top: 5px;
    color: #ffffff;
    font-size: 18px;
    -unity-font-style: bold;
    white-space: normal;
}

.mcb-dependencies__body {
    margin-top: 8px;
    color: #d1d1d1;
    font-size: 12px;
    white-space: normal;
}

.mcb-dependencies__list {
    margin-top: 14px;
}

.mcb-dependencies__row {
    flex-direction: row;
    align-items: flex-start;
    margin-bottom: 10px;
}

.mcb-dependencies__marker {
    width: 10px;
    height: 10px;
    border-radius: 5px;
    margin-top: 5px;
    margin-right: 10px;
    background-color: #ff8c59;
}

.mcb-dependencies__row-text {
    flex-grow: 1;
}

.mcb-dependencies__name {
    color: #ffffff;
    font-size: 13px;
    -unity-font-style: bold;
}

.mcb-dependencies__detail {
    color: #999999;
    font-size: 11px;
    white-space: normal;
}

.mcb-dependencies__actions {
    margin-top: 10px;
    flex-direction: row;
}

.mcb-dependencies__install-button {
    min-width: 180px;
}

.mcb-connectivity {
    background-color: rgba(0,0,0,0);
    padding: 8px 24px 16px 24px;
    flex-grow: 0;
    flex-shrink: 0;
}

.mcb-connectivity__panel {
    background-color: #191919;
    border-radius: 8px;
    border-left-width: 4px;
    border-left-color: #ff5a5a;
    padding: 14px;
}

.mcb-connectivity__panel--warning {
    border-left-color: #ffae28;
}

.mcb-connectivity__header {
    flex-direction: row;
    align-items: flex-start;
}

.mcb-connectivity__icon {
    width: 26px;
    height: 26px;
    min-width: 26px;
    margin-right: 10px;
    border-radius: 8px;
    background-color: #ff5a5a;
    color: #ffffff;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    font-size: 18px;
}

.mcb-connectivity__header-text {
    flex-grow: 1;
}

.mcb-connectivity__title {
    color: #ffffff;
    -unity-font-style: bold;
    font-size: 13px;
    white-space: normal;
}

.mcb-connectivity__body {
    margin-top: 3px;
    color: #d1d1d1;
    font-size: 12px;
    white-space: normal;
}

.mcb-connectivity__report {
    margin-top: 12px;
    min-height: 140px;
    max-height: 240px;
}

.mcb-connectivity__report .unity-base-field__input,
.mcb-connectivity__report .unity-base-text-field__input,
.mcb-connectivity__report .unity-text-field__input,
.mcb-connectivity__report .unity-text-input {
    background-color: #2b2b2b;
    color: #d1d1d1;
    border-width: 0;
    border-radius: 8px;
    padding: 8px;
}

.mcb-connectivity-report-loading {
    margin-top: 10px;
}

.mcb-connectivity-report-loading__label {
    color: #d1d1d1;
    font-size: 11px;
    white-space: normal;
}

.mcb-loading-bar.mcb-connectivity-report-loading__bar {
    position: relative;
    left: 0;
    right: auto;
    top: 0;
    height: 4px;
    margin-top: 6px;
    justify-content: flex-start;
    align-items: stretch;
}

.mcb-connectivity-report-loading__bar .mcb-loading-bar__track {
    width: 100%;
    max-width: none;
    background-color: #2b2b2b;
}

.mcb-connectivity__actions {
    margin-top: 10px;
    flex-direction: row;
    align-items: center;
}

.mcb-connectivity__actions .mcb-button {
    margin-right: 8px;
}

.mcb-connectivity-warnings {
    margin-top: 14px;
    padding-top: 12px;
    border-top-width: 1px;
    border-top-color: #333333;
}

.mcb-connectivity-warnings--first {
    margin-top: 0;
    padding-top: 0;
    border-top-width: 0;
}

.mcb-connectivity-warnings__header {
    flex-direction: row;
    align-items: flex-start;
}

.mcb-connectivity-warnings__icon {
    width: 24px;
    height: 24px;
    min-width: 24px;
    margin-right: 10px;
    border-radius: 7px;
    background-color: #ffae28;
    color: #141414;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    font-size: 16px;
}

.mcb-connectivity-warnings__text {
    flex-grow: 1;
}

.mcb-connectivity-warnings__title {
    color: #ffffff;
    -unity-font-style: bold;
    font-size: 13px;
    white-space: normal;
}

.mcb-connectivity-warnings__body {
    margin-top: 3px;
    color: #d1d1d1;
    font-size: 12px;
    white-space: normal;
}

.mcb-connectivity-warning {
    margin-top: 10px;
    background-color: #212121;
    border-radius: 8px;
    padding: 10px;
}

.mcb-connectivity-warning__title {
    color: #ffffff;
    -unity-font-style: bold;
    font-size: 12px;
}

.mcb-connectivity-warning__body {
    margin-top: 3px;
    color: #bdbdbd;
    font-size: 11px;
    white-space: normal;
}

.mcb-connectivity-overrides {
    margin-top: 14px;
    padding-top: 12px;
    border-top-width: 1px;
    border-top-color: #333333;
}

.mcb-connectivity-overrides__title {
    color: #ffb18c;
    font-size: 11px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.mcb-connectivity-override {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
    background-color: #212121;
    border-radius: 8px;
    padding: 10px;
}

.mcb-connectivity-override__text {
    flex-grow: 1;
}

.mcb-connectivity-override__title {
    color: #ffffff;
    -unity-font-style: bold;
    font-size: 12px;
}

.mcb-connectivity-override__body {
    margin-top: 2px;
    color: #999999;
    font-size: 11px;
    white-space: normal;
}

.mcb-connectivity-override__button {
    width: 86px;
    margin-left: 12px;
}

.mcb-connectivity-overrides__refresh {
    margin-top: 2px;
    min-width: 210px;
}
